SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_AUTH_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<server-side-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
PORT=3000
NODE_ENV=development

# 면접 코치 (AI) — 취업 브랜딩 패키지 표준: Claude Haiku 4.5. 모델 하드코딩 금지(env 단일 소스).
ANTHROPIC_API_KEY=<anthropic-api-key>
ANTHROPIC_COACH_MODEL=claude-haiku-4-5-20251001
# 폴백(선택). 미설정=폴백 없음. Gemini 3.5 Flash 교차 폴백은 fast-follow(ID·한도 실측 후).
# ANTHROPIC_COACH_FALLBACK_MODEL=
# ANTHROPIC_COACH_TIMEOUT_MS=60000
# 코치 데이터 디렉토리 오버라이드(기본 = shared/data/ai-interview 상대경로)
# AI_INTERVIEW_DATA_DIR=

VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<client-anon-key>
VITE_API_URL=http://localhost:3000
VITE_FEATURE_STT=false
